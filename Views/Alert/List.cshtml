@using dotnetApp.ViewModels.Alerts
@model AlertsListViewModel

<div class="card border-0 shadow-sm rounded-4">
    <!-- Header -->
    <div class="card-header bg-white border-bottom-0 py-3 px-4 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-1 fw-semibold text-dark">My Alerts</h5>
            <small class="text-muted">Active stock price alerts</small>
        </div>

        <button class="btn btn-primary rounded-pill px-4" onclick="openCreateModal()">
            + Create Alert
        </button>
    </div>

    <!-- Table -->
    <div class="table-responsive p-3">
        <table class="table table-striped table-hover align-middle mb-0 rounded-4 shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>Symbol</th>
                    <th>Condition</th>
                    <th>Target Price (LKR)</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Alerts.Any())
                {
                    foreach (var alert in Model.Alerts)
                    {
                        <tr>
                            <td class="fw-semibold">@alert.Symbol</td>
                            <td>
                                <span class="badge rounded-pill @(alert.IsAbove ? "bg-info text-dark" : "bg-warning text-dark")">
                                    @(alert.IsAbove ? "Above" : "Below")
                                </span>
                            </td>
                            <td>@alert.TargetPrice.ToString("N2")</td>
                            <td>
                                <span class="badge rounded-pill @(alert.IsActive ? "bg-success text-white" : "bg-secondary text-dark")">
                                    @(alert.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary rounded-circle me-1"
                                    onclick="openEditModal(this)"
                                    data-id="@alert.Id"
                                    data-symbol="@alert.Symbol"
                                    data-price="@alert.TargetPrice"
                                    data-isabove="@alert.IsAbove">
                                    <i class="fa fa-pen"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger rounded-circle"
                                    onclick="deactivateAlert(@alert.Id)">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No alerts found. Create your first alert.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- CREATE / EDIT ALERT MODAL -->
<div class="modal fade" id="editAlertModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-semibold" id="modalTitle">Create Alert</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <form id="alertForm">
                    <input type="hidden" id="alertId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Symbol</label>
                        <select id="symbol" required class="form-select form-select-lg rounded-3">
                            <option value="">-- Select Stock --</option>
                            @foreach (var stock in Model.StockNames)
                            {
                                <option value="@stock.Symbol">@stock.Symbol</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Target Price (LKR)</label>
                        <input type="number" step="0.01" class="form-control" id="targetPrice" required />
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="isAbove" />
                        <label class="form-check-label">Is Above?</label>
                    </div>

                    <div class="text-end">
                        <button type="button" class="btn btn-light rounded-pill me-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
let alertMode = 'create';

function openCreateModal() {
    alertMode = 'create';
    document.getElementById('modalTitle').innerText = 'Create Alert';
    document.getElementById('alertId').value = '';
    document.getElementById('symbol').value = '';
    document.getElementById('symbol').disabled = false;
    document.getElementById('targetPrice').value = '';
    document.getElementById('isAbove').checked = true;

    new bootstrap.Modal(document.getElementById('editAlertModal')).show();
}

function openEditModal(button) {
    alertMode = 'edit';
    document.getElementById('modalTitle').innerText = 'Edit Alert';
    const id = button.dataset.id;
    document.getElementById('alertId').value = id;
    document.getElementById('symbol').value = button.dataset.symbol;
    document.getElementById('symbol').disabled = true;
    document.getElementById('targetPrice').value = parseFloat(button.dataset.price).toFixed(2);
    document.getElementById('isAbove').checked = button.dataset.isabove.toLowerCase() === 'true';

    new bootstrap.Modal(document.getElementById('editAlertModal')).show();
}

// Create / Edit Alert
document.getElementById('alertForm').addEventListener('submit', async e => {
    e.preventDefault();
    const id = document.getElementById('alertId').value;

    const payload = {
        targetPrice: parseFloat(document.getElementById('targetPrice').value),
        isAbove: document.getElementById('isAbove').checked
    };

    let url = '/api/alerts';
    let method = 'POST';

    if (alertMode === 'edit' && id) {
        url += '/' + id;
        method = 'PUT';
    } else if (alertMode === 'create') {
        payload.symbol = document.getElementById('symbol').value;
        method = 'POST';
    } else {
        alert('Invalid operation');
        return;
    }

    const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    if (res.ok) location.reload();
    else alert('Something went wrong');
});

// Deactivate/Delete via API
async function deactivateAlert(id) {
    const res = await fetch(`/api/alerts/${id}`, { method: 'DELETE' });
    if (res.ok) location.reload();
    else alert('Failed to deactivate alert.');
}
</script>
